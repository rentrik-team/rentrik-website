# ─────────────────────────────────────────────────────────────
# Rentrik Web — Environment Variables
# Copy to .env.local for local dev: cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=https://rentrik.in
NEXT_PUBLIC_ENVIRONMENT=local

# Backend API (when available)
NEXT_PUBLIC_API_URL=

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Feature flags
NEXT_PUBLIC_SHOW_WAITLIST_FORM=true

# App store links (when available)
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# Server-only (never exposed to client)
RESEND_API_KEY=
